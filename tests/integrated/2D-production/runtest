output_path = data_dir / "BOUT.dmp.*.nc"

zipfile_path = this_dir / "test-2D-production.zip"
url = "https://zenodo.org/records/21416276/files/test-2D-production-2026-07-17.zip"
expected_hash = "55eabe4f040371fe47df5fe9116e6dc040b06ea2823555105607da9ac9421d9c"
expected_filenames = [
    "BOUT.restart.0.nc",
    "BOUT.restart.1.nc",
